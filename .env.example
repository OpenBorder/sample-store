# Open Border credentials. Copy to `.env` for local runs; on Vercel set these as
# environment variables in the project settings.

# SECRET key (server-only) — used by the backend to quote taxes and create payment intents.
OB_SECRET_KEY=sk_test_...

# PUBLISHABLE key (public; sent to the browser) — the checkout embed authenticates its
# read-only config call with it.
OB_PUBLISHABLE_KEY=pk_test_...

# Optional. When unset, the SDK and embed use the standard Open Border API host.
# For safety, this public demo accepts only localhost or an HTTPS staging/dev host here.
# OB_API_URL=https://api-staging.openborderpayments.com

# Live keys are intentionally refused. Do not place real credentials in this repository.

# Port for the local server (defaults to 4000).
# PORT=4000
