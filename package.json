{
  "name": "openborder-sample-store",
  "version": "0.1.0",
  "private": true,
  "description": "Sample storefront: cross-border checkout with the Open Border JS embed + Node SDK.",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check:secrets": "node scripts/check-secrets.mjs",
    "start": "tsx server.ts",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@open-border/node": "^0.4.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3"
  }
}
